<persistence xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="3.0" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
<persistence-unit name="ebs-PU" transaction-type="JTA">
<jta-data-source>jdbc/ebsDS</jta-data-source>
<!--  Existing entities — unchanged  -->
<class>com.ebs.entity.User</class>
<class>com.ebs.entity.Student</class>
<class>com.ebs.entity.Lecturer</class>
<class>com.ebs.entity.Lab</class>
<class>com.ebs.entity.Seat</class>
<class>com.ebs.entity.Booking</class>
<class>com.ebs.entity.OtpToken</class>
<!--  NEW: lecturer full-lab reservation entity  -->
<class>com.ebs.entity.LecturerBlock</class>
<!-- 
      NOTE: Admin.java and Complaint.java are listed in the original
      persistence.xml but the .java files do not exist in this project.
      They are intentionally excluded here. Adding them back before
      the .java files exist will crash deployment.
     -->
<properties>
<!-- 
        IMPORTANT: Keep this as "none".
        Schema is managed manually via 01_schema.sql.
        Changing back to "create" will DROP and recreate all tables
        on every redeploy, wiping real data.
       -->
<property name="jakarta.persistence.schema-generation.database.action" value="none"/>
<property name="eclipselink.logging.level.sql" value="FINE"/>
<property name="eclipselink.logging.parameters" value="true"/>
</properties>
</persistence-unit>
</persistence>