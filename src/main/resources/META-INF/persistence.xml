<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.1"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <persistence-unit name="ebs-PU" transaction-type="JTA">

        <!-- GlassFish JDBC Resource — configure in GlassFish admin console -->
        <jta-data-source>jdbc/ebsDS</jta-data-source>

        <!--
            Removed: com.ebs.entity.Admin and com.ebs.entity.Complaint
            Those classes do not exist and caused a deployment crash.
            Add them back once the responsible team members create the entities.
        -->
        <class>com.ebs.entity.User</class>
        <class>com.ebs.entity.Student</class>
        <class>com.ebs.entity.Lecturer</class>
        <class>com.ebs.entity.Lab</class>
        <class>com.ebs.entity.Seat</class>
        <class>com.ebs.entity.Booking</class>
        <class>com.ebs.entity.OtpToken</class>

        <properties>
            <!-- Create tables from entities on first deploy; switch to "none" in production -->
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <!-- SQL logging — remove for production -->
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
        </properties>

    </persistence-unit>

</persistence>
